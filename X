<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>كأس العالم 2026 | حوار الخبراء وبث مباشر</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body, html {
            width: 100%;
            height: 100%;
            overflow: hidden;
            font-family: 'Cairo', sans-serif;
            background: #000;
        }

        .top-black-bar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 45px;
            background-color: #000000;
            z-index: 300;
            box-shadow: 0 2px 8px rgba(0,0,0,0.8);
            border-bottom: 1px solid #ffd96655;
        }
        .bottom-black-bar {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 45px;
            background-color: #000000;
            z-index: 300;
            border-top: 1px solid #ffd96655;
        }

        .scene {
            position: relative;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background: #000;
        }

        /* حاوية الخلفية المتغيرة */
        .bg-container {
            position: absolute;
            inset: 0;
            overflow: hidden;
        }
        .bg-layer {
            position: absolute;
            inset: 0;
            background-size: cover;
            background-position: center 30%;
            filter: brightness(0.5) saturate(1.1);
            transform: scale(1.02);
            transition: opacity 1.8s ease-in-out;
            opacity: 0;
            will-change: opacity;
        }
        .bg-layer.active {
            opacity: 1;
        }
        .bg-layer.zoom {
            transform: scale(1);
            transition: transform 18s ease, opacity 1.8s ease-in-out;
        }

        .ground-gradient {
            position: absolute;
            bottom: 45px;
            left: 0;
            right: 0;
            height: 55%;
            background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.4) 60%, transparent 100%);
            pointer-events: none;
            z-index: 1;
        }

        .broadcast-bar {
            position: absolute;
            top: 45px;
            left: 0;
            right: 0;
            height: 58px;
            background: linear-gradient(90deg, #b8860b 0%, #121212 35%, #121212 65%, #9b2c2c 100%);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            z-index: 30;
            border-bottom: 2px solid #f5b042;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
        }

        .broadcast-logo {
            font-size: 1.1rem;
            font-weight: 900;
            color: #ffd966;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .broadcast-logo span { color: #ffffffcc; font-size: 0.75rem; }

        .live-pill {
            display: flex;
            align-items: center;
            gap: 8px;
            background: #c00000;
            color: white;
            font-weight: 900;
            font-size: 0.8rem;
            padding: 5px 16px;
            border-radius: 30px;
        }
        .live-dot {
            width: 10px;
            height: 10px;
            background: white;
            border-radius: 50%;
            animation: blink 1.2s infinite;
        }
        @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.2} }

        .broadcast-right { display: flex; gap: 18px; align-items: center; }
        .time-display {
            background: #000000aa;
            padding: 4px 12px;
            border-radius: 30px;
            font-weight: 700;
            font-size: 0.85rem;
            color: #ffd966;
            backdrop-filter: blur(2px);
        }
        .mute-btn {
            background: rgba(255,255,255,0.12);
            border: 1px solid rgba(255,215,0,0.5);
            color: #ffdb7e;
            border-radius: 50%;
            width: 38px;
            height: 38px;
            font-size: 1.2rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: 0.2s;
        }
        .mute-btn:hover { background: rgba(255,200,50,0.25); transform: scale(1.03); }

        .journalists-stage {
            position: absolute;
            bottom: 85px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            padding: 0 8%;
            z-index: 15;
        }
        .character { display: flex; flex-direction: column; align-items: center; position: relative; }
        .character-img-wrap { position: relative; filter: drop-shadow(0 12px 18px rgba(0,0,0,0.6)); }
        .character-img { height: 360px; width: auto; object-fit: contain; display: block; }
        .character-img-wrap::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 130%;
            height: 35px;
            background: radial-gradient(ellipse, rgba(210,180,50,0.45), transparent 70%);
            pointer-events: none;
        }
        .character.speaking .character-img {
            animation: speakBob 0.35s infinite ease-in-out;
            filter: drop-shadow(0 0 14px #ffcc44);
        }
        @keyframes speakBob {
            0%,100%{transform:translateY(0) rotate(0deg)}
            30%{transform:translateY(-5px) rotate(0.6deg)}
            70%{transform:translateY(2px) rotate(-0.4deg)}
        }
        .speak-glow {
            position: absolute;
            inset: -10px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,215,0,0.25), transparent 70%);
            opacity: 0;
            transition: opacity 0.2s;
            pointer-events: none;
        }
        .character.speaking .speak-glow { opacity: 1; }

        .name-card {
            position: absolute;
            bottom: 105px;
            z-index: 25;
        }
        .name-card.left { left: calc(50% - 380px); }
        .name-card.right { right: calc(50% - 380px); align-items: flex-end; }
        @media (max-width:860px){ .name-card.left{left:15px} .name-card.right{right:15px} .character-img{height:260px} }
        @media (max-width:560px){ .character-img{height:190px} }
        .name-card-inner {
            background: linear-gradient(135deg, #a5701a, #7a520f);
            padding: 5px 20px 5px 12px;
            clip-path: polygon(0 0, 100% 0, 96% 100%, 0 100%);
            margin-bottom: 6px;
            box-shadow: 0 3px 10px black;
        }
        .name-card.right .name-card-inner { clip-path: polygon(4% 0, 100% 0, 100% 100%, 0% 100%); padding: 5px 12px 5px 20px; }
        .name-card-name { color: white; font-weight: 900; font-size: 1.1rem; white-space: nowrap; }
        .name-card-role {
            background: #000000bb;
            color: #ffd966;
            font-size: 0.7rem;
            font-weight: 700;
            padding: 4px 12px;
            border-right: 3px solid #ffb347;
            white-space: nowrap;
            backdrop-filter: blur(4px);
        }
        .name-card.right .name-card-role { border-right: none; border-left: 3px solid #ffb347; }

        .ticker-bar {
            position: absolute;
            bottom: 45px;
            left: 0;
            right: 0;
            height: 44px;
            background: #0a0c12;
            border-top: 2px solid #cf9f2e;
            display: flex;
            align-items: center;
            overflow: hidden;
            z-index: 30;
            direction: ltr;
        }
        .ticker-label {
            background: #b22222;
            color: #ffdd99;
            font-weight: 900;
            font-size: 0.85rem;
            padding: 0 22px;
            height: 100%;
            display: flex;
            align-items: center;
            white-space: nowrap;
            flex-shrink: 0;
            clip-path: polygon(0 0, 92% 0, 100% 100%, 0 100%);
            padding-right: 28px;
            font-family: monospace;
            letter-spacing: 0.5px;
        }
        .ticker-track {
            overflow: hidden;
            flex: 1;
            white-space: nowrap;
            position: relative;
        }
        .ticker-content {
            display: inline-block;
            white-space: nowrap;
            animation: tickerScroll 45s linear infinite;
            padding-left: 20px;
        }
        .ticker-text {
            display: inline-block;
            white-space: nowrap;
            color: #f5e2b0;
            font-weight: 700;
            font-size: 0.95rem;
            font-family: 'Cairo', monospace;
            letter-spacing: 0.3px;
        }
        .ticker-text span {
            margin: 0 15px;
        }
        @keyframes tickerScroll {
            0% { transform: translateX(0%); }
            100% { transform: translateX(-50%); }
        }

        /* زر بدء البث (يظهر فقط إذا لم يبدأ الحوار تلقائياً) */
        .start-broadcast-btn {
            position: absolute;
            bottom: 120px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 50;
            background: radial-gradient(circle at 30% 10%, #ffdb7e, #c9921e);
            color: #1e2a1c;
            font-weight: 900;
            font-size: 1.3rem;
            padding: 16px 48px;
            border-radius: 80px;
            border: none;
            box-shadow: 0 8px 28px rgba(0,0,0,0.6), 0 0 0 2px #ffe6a3 inset;
            cursor: pointer;
            font-family: 'Cairo', sans-serif;
            transition: all 0.3s;
            display: none; /* مخفي افتراضياً */
            animation: gentlePulse 1.8s infinite;
        }
        .start-broadcast-btn:hover {
            transform: translateX(-50%) scale(1.05);
            box-shadow: 0 8px 40px rgba(218,165,32,0.8), 0 0 0 3px #fff0bb inset;
        }
        .start-broadcast-btn.show {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        @keyframes gentlePulse {
            0%,100%{ box-shadow: 0 8px 28px rgba(0,0,0,0.6), 0 0 0 2px #ffe6a3 inset; }
            50%{ box-shadow: 0 8px 44px rgba(218,165,32,0.8), 0 0 0 2px #fff0bb inset; }
        }
    </style>
</head>
<body>

    <div class="top-black-bar"></div>
    <div class="bottom-black-bar"></div>

    <div class="scene">
        <!-- حاوية الخلفية المتغيرة -->
        <div class="bg-container" id="bgContainer">
            <div class="bg-layer active zoom" id="bg1"></div>
            <div class="bg-layer" id="bg2"></div>
        </div>
        <div class="ground-gradient"></div>

        <div class="broadcast-bar">
            <div class="broadcast-logo">🏆 قناة المونديال HD<span>| World Cup 2026 Live</span></div>
            <div class="live-pill"><div class="live-dot"></div>بث حي</div>
            <div class="broadcast-right"><div class="time-display" id="clockDisplay">00:00</div><button class="mute-btn" id="muteBtn">🔊</button></div>
        </div>

        <div class="journalists-stage">
            <div class="character" id="char1"><div class="character-img-wrap"><div class="speak-glow"></div><img class="character-img" src="https://images.unsplash.com/photo-1560250097-0b93528c311a?w=400&h=700&fit=crop&crop=faces&auto=format&q=85" alt="أحمد الكروي" onerror="this.src='https://images.pexels.com/photos/3772625/pexels-photo-3772625.jpeg?w=300&h=600&fit=crop'"></div></div>
            <div class="character" id="char2"><div class="character-img-wrap"><div class="speak-glow"></div><img class="character-img" src="https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=400&h=700&fit=crop&crop=faces&auto=format&q=85" alt="سامر الناقد" onerror="this.src='https://images.pexels.com/photos/2379004/pexels-photo-2379004.jpeg?w=300&h=600&fit=crop'"></div></div>
        </div>

        <div class="name-card left"><div class="name-card-inner"><div class="name-card-name">🎙️ أحمد الكروي</div></div><div class="name-card-role">مذيع أسطوري - خبير كأس العالم</div></div>
        <div class="name-card right"><div class="name-card-inner"><div class="name-card-name">⚡ سامر الناقد</div></div><div class="name-card-role">محلل تكتيكي واستراتيجيات المونديال</div></div>

        <!-- شريط أوقات المباريات -->
        <div class="ticker-bar">
            <div class="ticker-label">⚽ MATCH SCHEDULE 2026</div>
            <div class="ticker-track">
                <div class="ticker-content">
                    <div class="ticker-text">
                        🏆 FIFA WORLD CUP 2026 - 48 TEAMS 🏆 &nbsp;|&nbsp;
                        🇿🇦 RSA vs 🇲🇽 MEX - JUNE 11 &nbsp;|&nbsp;
                        🇺🇸 USA vs 🇨🇦 CAN - JUNE 12 &nbsp;|&nbsp;
                        🇧🇷 BRA vs 🇩🇪 GER - JUNE 15 &nbsp;|&nbsp;
                        🇫🇷 FRA vs 🇦🇷 ARG - JUNE 18 &nbsp;|&nbsp;
                        🏆 FINAL: JULY 19 - METLIFE STADIUM ⚽ &nbsp;|&nbsp;
                        🎟️ TICKETS AVAILABLE NOW &nbsp;|&nbsp;
                        🇿🇦 RSA vs 🇲🇽 MEX - JUNE 11 &nbsp;|&nbsp;
                        🇺🇸 USA vs 🇨🇦 CAN - JUNE 12 &nbsp;|&nbsp;
                        🇧🇷 BRA vs 🇩🇪 GER - JUNE 15 &nbsp;|&nbsp;
                        🇫🇷 FRA vs 🇦🇷 ARG - JUNE 18 &nbsp;|&nbsp;
                        🏆 FINAL: JULY 19 - METLIFE STADIUM ⚽ &nbsp;|&nbsp;
                    </div>
                </div>
            </div>
        </div>

        <!-- زر بدء البث (يظهر إذا لم يبدأ الحوار تلقائياً) -->
        <button id="startBroadcastBtn" class="start-broadcast-btn">▶️ بدء البث</button>
    </div>

    <script>
        // ======================= 3 صور خلفية متبدلة كل 30 ثانية =======================
        const backgroundImages = [
            'https://images.pexels.com/photos/3162069/pexels-photo-3162069.jpeg?auto=compress&cs=tinysrgb&w=1920',
            'https://images.pexels.com/photos/3171841/pexels-photo-3171841.jpeg?auto=compress&cs=tinysrgb&w=1920',
            'https://images.pexels.com/photos/2600243/pexels-photo-2600243.jpeg?auto=compress&cs=tinysrgb&w=1920'
        ];

        const bg1 = document.getElementById('bg1');
        const bg2 = document.getElementById('bg2');
        let currentIndex = 0;
        let nextIndex = 1;
        let isBg1Active = true;
        let intervalId = null;

        bg1.style.backgroundImage = `url(${backgroundImages[0]})`;
        bg2.style.backgroundImage = `url(${backgroundImages[1]})`;
        bg1.classList.add('active');
        bg2.classList.remove('active');

        function switchBackground() {
            const activeLayer = isBg1Active ? bg1 : bg2;
            const inactiveLayer = isBg1Active ? bg2 : bg1;

            activeLayer.classList.remove('active');
            inactiveLayer.classList.add('active');

            const newInactiveLayer = isBg1Active ? bg1 : bg2;
            setTimeout(() => {
                const nextImg = backgroundImages[(nextIndex + 1) % backgroundImages.length];
                newInactiveLayer.style.backgroundImage = `url(${nextImg})`;
            }, 100);

            currentIndex = nextIndex;
            nextIndex = (nextIndex + 1) % backgroundImages.length;
            isBg1Active = !isBg1Active;
        }

        function startBackgroundRotation() {
            if (intervalId) clearInterval(intervalId);
            intervalId = setInterval(switchBackground, 30000);
        }

        document.querySelectorAll('.bg-layer').forEach(el => el.classList.add('zoom'));
        startBackgroundRotation();

        window.addEventListener('beforeunload', () => {
            if (intervalId) clearInterval(intervalId);
            if (speechSynth) speechSynth.cancel();
            if (clockInterval) clearInterval(clockInterval);
        });

        // ======================= الحوار الصوتي =======================
        let dialogueStarted = false;
        let conversationEnded = false;
        let currentDialogueIndex = 0;
        let isMuted = false;
        let speechSynth = window.speechSynthesis;
        let currentUtterance = null;
        let voiceMap = { journalist1: null, journalist2: null };
        let clockInterval = null;
        let secondsElapsed = 0;

        const DIALOGUE = [
            { speaker: "journalist1", text: "جمهورنا العزيز، أهلاً بكم في بث مباشر. معنا الخبير سامر الناقد لنستعرض ملامح كأس العالم 2026." },
            { speaker: "journalist2", text: "شكراً أحمد. هذه النسخة ستُقام في أمريكا وكندا والمكسيك، بمشاركة 48 منتخباً لأول مرة." },
            { speaker: "journalist1", text: "هل تتذكر يا سامر أول كأس عالم عام 1930 في الأوروغواي؟ كان عدد المنتخبات 13 فقط، والأوروغواي بطلة." },
            { speaker: "journalist2", text: "طبعاً، التاريخ يزخر باللحظات الخالدة. توقفت البطولة مرتين بسبب الحرب العالمية، لكنها عادت بقوة عام 1950." },
            { speaker: "journalist1", text: "البرازيل هي سيدة الكأس بخمسة ألقاب: 1958، 1962، 1970، 1994، 2002. يليها ألمانيا وإيطاليا بأربعة." },
            { speaker: "journalist2", text: "بيليه الأسطورة الوحيد الذي رفع الكأس ثلاث مرات. وكلوزه سجل 16 هدفاً في المونديال. وميسي حقق حلمه في 2022." },
            { speaker: "journalist1", text: "نهائي قطر 2022 كان ملحمة: الأرجنتين وفرنسا 3-3 ثم الترجيح. هل يتكرر المشهد في 2026؟" },
            { speaker: "journalist2", text: "أتوقع أن فرنسا مرشح قوي للقب الثالث، والبرازيل تريد النجمة السادسة. التنافس سيكون على أشده." },
            { speaker: "journalist1", text: "ألمانيا عادت بقوة مع ناغلسمان، وإنجلترا مع بيلينغهام، والمغرب قد يفاجئ العالم مجدداً." },
            { speaker: "journalist2", text: "التوسيع إلى 48 فريقاً سيمنح فرصة لأكثر من 20 منتخباً جديداً، والجماهيرية ستكون ضخمة في أمريكا الشمالية." },
            { speaker: "journalist1", text: "من تتوقع في النهائي يا سامر؟ البرازيل أم فرنسا؟" },
            { speaker: "journalist2", text: "سأضع البرازيل وفرنسا في النهائي، وأميل للبرازيل لتحقيق السادسة بفضل هجومها الخيالي." },
            { speaker: "journalist1", text: "أنا أميل إلى فرنسا بفضل خبرة ديشامب ومبابي الحاسم. لكن الأرجنتين إن حافظت على نضجها قد تكون مفاجأة." },
            { speaker: "journalist2", text: "ستكون مفاجآت لا حصر لها. نشكر المشاهدين على متابعة هذا الحوار المثير." },
            { speaker: "journalist1", text: "ختاماً، احلموا معنا بكأس العالم 2026 الأجمل في التاريخ. تحيا كرة القدم!" },
            { speaker: "journalist2", text: "من الاستوديو، نعدكم بتغطية لا مثيل لها. وإلى اللقاء في الملاعب!" }
        ];

        const char1 = document.getElementById('char1');
        const char2 = document.getElementById('char2');
        const startBtn = document.getElementById('startBroadcastBtn');

        function loadVoices() {
            const voices = speechSynth.getVoices();
            if (!voices.length) return;
            const arabicVoice = voices.find(v => v.lang.includes('ar') || v.lang.includes('AR'));
            if (arabicVoice) {
                voiceMap.journalist1 = arabicVoice;
                voiceMap.journalist2 = voices.find(v => v !== arabicVoice && v.lang.includes('ar')) || arabicVoice;
            } else {
                voiceMap.journalist1 = voices[0];
                voiceMap.journalist2 = voices[0];
            }
        }
        speechSynth.onvoiceschanged = loadVoices;
        loadVoices();

        function setSpeaking(speakerKey) {
            char1.classList.remove('speaking');
            char2.classList.remove('speaking');
            if (speakerKey === 'journalist1') char1.classList.add('speaking');
            else if (speakerKey === 'journalist2') char2.classList.add('speaking');
        }

        function speakLineAndWait(text, speakerKey) {
            return new Promise((resolve) => {
                if (isMuted || !speechSynth) {
                    setTimeout(resolve, Math.max(text.length * 70, 1500));
                    return;
                }
                try {
                    const utterance = new SpeechSynthesisUtterance(text);
                    utterance.lang = 'ar-SA';
                    utterance.rate = 0.95;
                    utterance.pitch = speakerKey === 'journalist1' ? 0.95 : 1.05;
                    if (voiceMap[speakerKey]) utterance.voice = voiceMap[speakerKey];
                    utterance.onend = () => resolve();
                    utterance.onerror = () => resolve();
                    currentUtterance = utterance;
                    speechSynth.speak(utterance);
                } catch(e) { setTimeout(resolve, text.length * 80); }
            });
        }

        async function runConversation() {
            if (conversationEnded) return;
            if (currentDialogueIndex >= DIALOGUE.length) {
                conversationEnded = true;
                setSpeaking(null);
                if (currentUtterance) speechSynth.cancel();
                if (clockInterval) clearInterval(clockInterval);
                return;
            }
            const line = DIALOGUE[currentDialogueIndex];
            setSpeaking(line.speaker);
            await speakLineAndWait(line.text, line.speaker);
            if (conversationEnded) return;
            currentDialogueIndex++;
            runConversation();
        }

        function startDialogue() {
            if (dialogueStarted) return;
            dialogueStarted = true;
            currentDialogueIndex = 0;
            // إخفاء زر البدء
            startBtn.classList.remove('show');
            runConversation();
            secondsElapsed = 0;
            if (clockInterval) clearInterval(clockInterval);
            clockInterval = setInterval(() => {
                if (!conversationEnded) {
                    secondsElapsed++;
                    let mins = Math.floor(secondsElapsed / 60);
                    let secs = secondsElapsed % 60;
                    document.getElementById('clockDisplay').textContent = `${mins.toString().padStart(2,'0')}:${secs.toString().padStart(2,'0')}`;
                }
            }, 1000);
        }

        // محاولة بدء الحوار تلقائياً بعد تحميل الصفحة
        // إذا لم يبدأ بعد 3 ثوانٍ، نظهر زر البدء
        let autoStartTimer = setTimeout(() => {
            if (!dialogueStarted) {
                startBtn.classList.add('show');
                // عند النقر على الزر، نبدأ الحوار
                startBtn.addEventListener('click', startDialogue, { once: true });
                // أيضاً نبدأ الحوار عند أي نقرة على الصفحة (كحل احتياطي)
                document.addEventListener('click', startDialogue, { once: true });
            }
        }, 3000);

        // محاولة البدء فوراً (قد يعمل في بعض المتصفحات)
        // لكن إذا فشل، سيظهر الزر بعد 3 ثوانٍ
        setTimeout(() => {
            if (!dialogueStarted) {
                startDialogue();
            }
        }, 500);

        // مستمع زر كتم الصوت
        document.getElementById('muteBtn').addEventListener('click', () => {
            isMuted = !isMuted;
            const muteBtn = document.getElementById('muteBtn');
            muteBtn.innerHTML = isMuted ? '🔇' : '🔊';
            if (isMuted && currentUtterance) { speechSynth.cancel(); setSpeaking(null); }
            else if (!isMuted && dialogueStarted && !conversationEnded && currentDialogueIndex < DIALOGUE.length) {
                const line = DIALOGUE[currentDialogueIndex];
                setSpeaking(line.speaker);
                speakLineAndWait(line.text, line.speaker).then(() => {
                    if (!conversationEnded) { currentDialogueIndex++; runConversation(); }
                });
            }
        });
    </script>
</body>
</html>
